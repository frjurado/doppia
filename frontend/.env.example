VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>
# Public base URL for piano soundfont MP3s. Loaded by Tone.js Sampler at
# {VITE_SOUNDFONT_BASE_URL}/soundfonts/piano/{note}.mp3 (28 files, C1–C7).
# Local dev: use MinIO public URL, e.g. http://localhost:9000/doppia-local
# Staging/production: use R2.dev public URL or custom domain (see docs/deployment.md).
# Leave empty to disable MIDI playback (sampler will time out after 10 s).
VITE_SOUNDFONT_BASE_URL=http://localhost:9000/doppia-local
