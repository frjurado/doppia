# Application environment: local | staging | production
ENVIRONMENT=local

# Auth mode: local | supabase
# local is only valid when ENVIRONMENT=local (app refuses to start otherwise)
AUTH_MODE=local

# Neo4j — bolt://neo4j:7687 inside Docker, bolt://localhost:7687 outside
# Note: Aura instances use a generated username (instance ID), not "neo4j"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=localpassword
NEO4J_AUTH=neo4j/localpassword

# PostgreSQL — use host=postgres inside Docker, host=localhost outside
POSTGRES_USER=postgres
POSTGRES_PASSWORD=localpassword
POSTGRES_DB=doppia
DATABASE_URL=postgresql+asyncpg://postgres:localpassword@localhost/doppia

# Redis — redis://localhost:6379 locally, Upstash URL in staging/production
REDIS_URL=redis://localhost:6379
REDIS_TOKEN=

# Object storage (MinIO locally, Cloudflare R2 in production)
R2_ACCOUNT_ID=
R2_ENDPOINT_URL=http://localhost:9000
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=doppia-local

# Supabase Auth — not needed when AUTH_MODE=local
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# New Supabase projects use ES256 asymmetric signing. The JWKS is fetched automatically
# at startup from SUPABASE_URL/auth/v1/.well-known/jwks.json — no extra variable needed.
# Legacy projects using HS256 symmetric signing: set SUPABASE_JWT_SECRET instead.
SUPABASE_JWT_SECRET=

# OpenAI — not needed until Phase 3 (prose embeddings)
OPENAI_API_KEY=

# Celery broker — same as REDIS_URL
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
