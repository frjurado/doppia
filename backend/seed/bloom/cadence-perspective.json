  "savedSearchPhrases": [
    {
      "name": "Show all cadence subtypes",
      "cypher": "MATCH (c:Concept)-[:IS_SUBTYPE_OF*1..]->(root:Concept {id: 'Cadence'}) RETURN c, root"
    },
    {
      "name": "Show PAC stage structure",
      "cypher": "MATCH (pac:Concept {id: 'PerfectAuthenticCadence'})-[:CONTAINS]->(stage) RETURN pac, stage"
    },
    {
      "name": "Show concept and its schemas",
      "cypher": "MATCH (c:Concept {name: $name})-[:IS_SUBTYPE_OF*0..]->(ancestor)-[:HAS_PROPERTY_SCHEMA]->(s)-[:HAS_VALUE]->(v) OPTIONAL MATCH (v)-[:VALUE_REFERENCES]->(ref) RETURN c, ancestor, s, v, ref",
      "parameters": [
        { "name": "name", "type": "text", "example": "Perfect Authentic Cadence" }
      ]
    },
    {
      "name": "Show prerequisite chain for concept",
      "cypher": "MATCH path = (c:Concept {name: $name})<-[:PREREQUISITE_FOR*1..]-(:Concept) RETURN nodes(path), relationships(path)",
      "parameters": [
        { "name": "name", "type": "text", "example": "Perfect Authentic Cadence" }
      ]
    },
    {
      "name": "Show all stub nodes",
      "cypher": "MATCH (c:Concept {stub: true}) RETURN c"
    },
    {
      "name": "Show concepts contrasting with",
      "cypher": "MATCH (a:Concept {name: $name})-[:CONTRASTS_WITH]-(b:Concept) RETURN a, b",
      "parameters": [
        { "name": "name", "type": "text", "example": "Authentic Cadence" }
      ]
    }
  ]
}
