<?xml version="1.0" encoding="UTF-8"?>
<!-- Fixture: multi-instrument score — Pass 11 must be a conservative no-op.

     Two leaf staffGrps (a 2-staff piano group and a single-staff instrument
     group), neither braced.  Because there is more than one leaf group, Pass 11
     leaves the staff presentation entirely untouched: it must never force a
     brace across unrelated instruments or strip their labels. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Multi-instrument no-op</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4">
            <staffGrp>
              <staffGrp>
                <staffDef n="1" clef.shape="G" clef.line="2" lines="5"/>
                <staffDef n="2" clef.shape="F" clef.line="4" lines="5"/>
              </staffGrp>
              <staffGrp>
                <staffDef n="3" label="Violin" clef.shape="G" clef.line="2" lines="5"/>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <measure n="1">
              <staff n="1"><layer n="1"><note dur="1" oct="4" pname="c"/></layer></staff>
              <staff n="2"><layer n="1"><note dur="1" oct="3" pname="c"/></layer></staff>
              <staff n="3"><layer n="1"><note dur="1" oct="5" pname="c"/></layer></staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
