<?xml version="1.0" encoding="UTF-8"?>
<!-- Fixture: key-signature-implied gestural accidentals, flat key.
     F major (key.sig="1f": Bb).  Staff 1 has two Bb5 notes whose
     accid.ges="f" is explained entirely by the key signature — no prior
     explicit @accid in the measure.  Both must be PRESERVED by pass 8.

     After pass 8: both accid.ges="f" are untouched; changes_applied is empty. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Key-signature flat carry fixture</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="1f">
            <staffGrp>
              <staffDef n="1" clef.shape="G" clef.line="2" lines="5"/>
            </staffGrp>
          </scoreDef>
          <section>
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <!-- Bb5 first: key-signature carry — must be KEPT -->
                  <note xml:id="n_b5_first" dur="4" oct="5" pname="b">
                    <accid xml:id="a_b5_first" accid.ges="f" glyph.auth="smufl"/>
                  </note>
                  <!-- Bb5 second: also key-signature carry — must be KEPT -->
                  <note xml:id="n_b5_second" dur="4" oct="5" pname="b">
                    <accid xml:id="a_b5_second" accid.ges="f" glyph.auth="smufl"/>
                  </note>
                  <note xml:id="n_c5" dur="2" oct="5" pname="c">
                    <accid xml:id="a_c5"/>
                  </note>
                </layer>
              </staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
