<?xml version="1.0" encoding="UTF-8"?>
<!-- Fixture: key-signature carry and within-staff carry coexist.
     G major (key.sig="1s": F#).  The measure has:

     1. F#5 with accid="n" accid.ges="n": notated natural sign cancelling the
        key signature.  Explicit — recorded for within-staff carry.
     2. F5 (same octave) with accid.ges="n" glyph.auth="smufl": within-staff
        carry of the natural.  The key signature would imply "s", but the
        carry value "n" takes precedence.  Must be PRESERVED.

     After pass 8: both accid elements untouched; changes_applied is empty. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Key-sig + carry coexist fixture</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp>
              <staffDef n="1" clef.shape="G" clef.line="2" lines="5"/>
            </staffGrp>
          </scoreDef>
          <section>
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <!-- F natural (explicit): cancels key-sig F#; recorded for carry -->
                  <note xml:id="n_f5_natural" dur="4" oct="5" pname="f">
                    <accid xml:id="a_f5_natural" accid="n" accid.ges="n"/>
                  </note>
                  <!-- Same F5, same octave: within-staff carry of the natural
                       (key sig says "s", but carry says "n" — carry wins) -->
                  <note xml:id="n_f5_carry" dur="4" oct="5" pname="f">
                    <accid xml:id="a_f5_carry" accid.ges="n" glyph.auth="smufl"/>
                  </note>
                  <note xml:id="n_g5" dur="2" oct="5" pname="g">
                    <accid xml:id="a_g5"/>
                  </note>
                </layer>
              </staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
