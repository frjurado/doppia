<?xml version="1.0" encoding="UTF-8"?>
<!-- Fixture: shape B — over-nested grand staff missing its brace (K332/i shape).

     outer staffGrp > middle staffGrp > inner staffGrp(bar.thru="true", no brace)
     > two staffDef.  Pass 11 adds a <grpSym symbol="brace"/> to the leaf (inner)
     group; bar.thru is already present.  The redundant empty middle group is
     left in place. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Unbraced over-nested grand staff</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4">
            <staffGrp>
              <staffGrp>
                <staffGrp bar.thru="true">
                  <instrDef midi.channel="0" midi.instrnum="0"/>
                  <staffDef n="1" clef.shape="G" clef.line="2" lines="5"/>
                  <staffDef n="2" clef.shape="F" clef.line="4" lines="5"/>
                </staffGrp>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <measure n="1">
              <staff n="1"><layer n="1"><note dur="1" oct="4" pname="c"/></layer></staff>
              <staff n="2"><layer n="1"><note dur="1" oct="3" pname="c"/></layer></staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
