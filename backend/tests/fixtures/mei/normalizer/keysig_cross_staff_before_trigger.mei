<?xml version="1.0" encoding="UTF-8"?>
<!-- Fixture: spurious accid.ges on a note that precedes the triggering
     explicit accidental in document order.

     C major (no key sig).  The measure has staff n=2 (bass) BEFORE staff n=1
     (treble) in document order — an unusual but valid MEI layout that
     reproduces the scenario where the converter writes the spurious element
     before the accid="s" that caused it.

     - Bass C4 (staff 2, first in document): accid.ges="s" glyph.auth="smufl".
       No key-sig cause (C major), no carry within staff 2.  Must be STRIPPED.
     - Treble C5 (staff 1, second in document): accid="s" accid.ges="s".
       Explicit — unchanged.

     After pass 8: bass accid.ges stripped; treble note unchanged. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Cross-staff spurious before trigger fixture</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4">
            <staffGrp>
              <staffDef n="1" clef.shape="G" clef.line="2" lines="5"/>
              <staffDef n="2" clef.shape="F" clef.line="4" lines="5"/>
            </staffGrp>
          </scoreDef>
          <section>
            <measure n="1">
              <!-- Staff 2 (bass) appears FIRST in document order -->
              <staff n="2">
                <layer n="1">
                  <!-- C4 spurious: appears before the treble trigger in doc order.
                       No key-sig (C major), no carry in staff 2 -> STRIPPED. -->
                  <note xml:id="n_bass_c4_early" dur="4" oct="4" pname="c">
                    <accid xml:id="a_bass_c4_early" accid.ges="s" glyph.auth="smufl"/>
                  </note>
                  <note xml:id="n_bass_g3" dur="4" oct="3" pname="g">
                    <accid xml:id="a_bass_g3"/>
                  </note>
                  <note xml:id="n_bass_e3" dur="2" oct="3" pname="e">
                    <accid xml:id="a_bass_e3"/>
                  </note>
                </layer>
              </staff>
              <!-- Staff 1 (treble) appears SECOND in document order -->
              <staff n="1">
                <layer n="1">
                  <!-- C#5 explicit: accid + accid.ges — the "trigger". Unchanged. -->
                  <note xml:id="n_treble_c5" dur="4" oct="5" pname="c">
                    <accid xml:id="a_treble_c5" accid="s" accid.ges="s"/>
                  </note>
                  <note xml:id="n_treble_e5" dur="2" oct="5" pname="e">
                    <accid xml:id="a_treble_e5"/>
                  </note>
                  <note xml:id="n_treble_g5" dur="4" oct="5" pname="g">
                    <accid xml:id="a_treble_g5"/>
                  </note>
                </layer>
              </staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
