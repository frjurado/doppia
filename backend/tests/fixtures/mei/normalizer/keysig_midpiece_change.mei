<?xml version="1.0" encoding="UTF-8"?>
<!-- Fixture: mid-movement key signature change.
     Measure 1 is in C major (no key sig).  A <scoreDef key.sig="1s"/> between
     the measures shifts to G major (F#).

     - Measure 1 F5 with accid.ges="s" glyph.auth="smufl": no key sig, no carry
       in the measure -> SPURIOUS, must be stripped.
     - Measure 2 F5 with accid.ges="s" glyph.auth="smufl": F# is key-sig implied
       in G major -> LEGITIMATE, must be PRESERVED.

     After pass 8: m1_f5 has accid.ges removed; m2_f5 is untouched. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Mid-piece key change fixture</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp>
              <staffDef n="1" clef.shape="G" clef.line="2" lines="5"/>
            </staffGrp>
          </scoreDef>
          <section>
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <!-- F5 in C major with accid.ges="s": spurious — must be STRIPPED -->
                  <note xml:id="n_m1_f5" dur="4" oct="5" pname="f">
                    <accid xml:id="a_m1_f5" accid.ges="s" glyph.auth="smufl"/>
                  </note>
                  <note xml:id="n_m1_g5" dur="2" oct="5" pname="g">
                    <accid xml:id="a_m1_g5"/>
                  </note>
                  <note xml:id="n_m1_e5" dur="4" oct="5" pname="e">
                    <accid xml:id="a_m1_e5"/>
                  </note>
                </layer>
              </staff>
            </measure>
            <!-- Key change: C major → G major (1 sharp: F#) -->
            <scoreDef key.sig="1s"/>
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <!-- F5 in G major with accid.ges="s": key-sig carry — must be KEPT -->
                  <note xml:id="n_m2_f5" dur="4" oct="5" pname="f">
                    <accid xml:id="a_m2_f5" accid.ges="s" glyph.auth="smufl"/>
                  </note>
                  <note xml:id="n_m2_g5" dur="2" oct="5" pname="g">
                    <accid xml:id="a_m2_g5"/>
                  </note>
                  <note xml:id="n_m2_e5" dur="4" oct="5" pname="e">
                    <accid xml:id="a_m2_e5"/>
                  </note>
                </layer>
              </staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
