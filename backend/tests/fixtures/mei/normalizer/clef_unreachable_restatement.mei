<?xml version="1.0" encoding="UTF-8"?>
<!-- Fixture (ADR-031 amendment, 2026-07-05): the K310/ii m.70 shape — the
     second voice's sameas restatement sits at an onset the change point
     cannot reach (a SOUNDING note spans the change point, and a note is
     never split).  The restatement must stay where it is, silent (no
     shape/line, @sameas kept): it draws no glyph but still repositions the
     voice's later notes.  The anchor voice's explicit clef is the single
     glyph at the true change point.
     4 ppq per quarter; 4/4 (16-tick bars).
       layer 1: eighth c3, CLEF G (t=2), then notes  — the anchor voice.
       layer 2: quarter g2 (t=0..4, sounds ACROSS t=2), sameas (t=4), notes. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Unreachable clef restatement stays silent</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4">
            <staffGrp>
              <staffDef n="1" clef.shape="F" clef.line="4" lines="5"/>
            </staffGrp>
          </scoreDef>
          <section>
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note dur="8" dur.ppq="2" oct="3" pname="c"/>
                  <clef xml:id="c-anchor" shape="G" line="2"/>
                  <note dur="8" dur.ppq="2" oct="4" pname="f"/>
                  <note dur="2" dur.ppq="8" oct="4" pname="g"/>
                  <note dur="4" dur.ppq="4" oct="4" pname="a"/>
                </layer>
                <layer n="2">
                  <note dur="4" dur.ppq="4" oct="2" pname="g"/>
                  <clef xml:id="c-stuck" sameas="#c-anchor"/>
                  <note dur="2" dur.ppq="8" oct="4" pname="e"/>
                  <note dur="4" dur.ppq="4" oct="4" pname="d"/>
                </layer>
              </staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
