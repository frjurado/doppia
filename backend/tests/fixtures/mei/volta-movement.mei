<?xml version="1.0" encoding="UTF-8"?>
<!-- Minimal MEI fixture for volta-handling integration tests.
     Structure (4 measures, positions 1–4):
       position 1: measure n=1  (volta=None)
       position 2: measure n=2  inside ending n=1  (volta=1)
       position 3: measure n=2  inside ending n=2  (volta=2)
       position 4: measure n=3  (volta=None)
     _build_measure_map produces {1: MeasureEntry("1",None,…), 2: MeasureEntry("2",1,…),
                                   3: MeasureEntry("2",2,…), 4: MeasureEntry("3",None,…)}.
     A 4-event TSV with mc=1,2,3,4 produces zero alignment warnings. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Volta movement — integration test fixture</title></titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4">
            <staffGrp>
              <staffDef n="1" clef.shape="G" clef.line="2" lines="5"/>
            </staffGrp>
          </scoreDef>
          <section>
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note dur="4" oct="4" pname="c"/>
                  <note dur="4" oct="4" pname="e"/>
                  <note dur="4" oct="4" pname="g"/>
                  <note dur="4" oct="4" pname="c"/>
                </layer>
              </staff>
            </measure>
            <ending n="1">
              <measure n="2">
                <staff n="1">
                  <layer n="1">
                    <note dur="4" oct="4" pname="g"/>
                    <note dur="4" oct="4" pname="b"/>
                    <note dur="4" oct="4" pname="d"/>
                    <note dur="4" oct="4" pname="g"/>
                  </layer>
                </staff>
              </measure>
            </ending>
            <ending n="2">
              <measure n="2">
                <staff n="1">
                  <layer n="1">
                    <note dur="4" oct="4" pname="f"/>
                    <note dur="4" oct="4" pname="a"/>
                    <note dur="4" oct="4" pname="c"/>
                    <note dur="4" oct="4" pname="f"/>
                  </layer>
                </staff>
              </measure>
            </ending>
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note dur="4" oct="4" pname="c"/>
                  <note dur="4" oct="4" pname="e"/>
                  <note dur="4" oct="4" pname="g"/>
                  <note dur="4" oct="4" pname="c"/>
                </layer>
              </staff>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
